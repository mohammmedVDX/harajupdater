// ==/UserScript==

(function() {
    'use strict';
    const VERSION = '6.6.2';
    
    // OpenRouter API Configuration (obfuscated key, no specific @connect needed)
    const OPENROUTER_CONFIG = {
        apiKey: atob('c2stb3ItdjEtZThlOGNjZjMyOTYxMGRiYjA4ODMxYzExYmU5YWY2ZThmMWFiN2UyYzgyN2IzYjc2YzQ5MzhiYmE4MTY5NGVjOA=='),
