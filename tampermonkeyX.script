    function createMenu() {
        // Create toggle button
        const toggleBtn = document.createElement('div');
        toggleBtn.id = 'haraj-toggle-btn';
        toggleBtn.innerHTML = '🔄';
        document.body.appendChild(toggleBtn);
        
        // Create menu
        const menu = document.createElement('div');
        menu.id = 'haraj-menu';
        menu.innerHTML = `
            <div id="haraj-header">
                <h3>🔄 محدث حراج <span class="version-badge">v${VERSION}</span></h3>
                <button class="minimize-btn">−</button>
            </div>
            <div id="haraj-content">
                <div class="token-warning" id="token-warning">⚠️ انتهت الجلسة - مشكلة من السيرفر</div>
                <button class="btn-relogin" id="relogin-btn">🔄 إعادة تسجيل الدخول</button>
                <div class="speed-control">
                    <button class="speed-btn" data-speed="3">3 دفعة</button>
                    <button class="speed-btn active" data-speed="6">6 دفعة</button>
                    <button class="speed-btn" data-speed="12">12 دفعة</button>
                </div>
                <div class="btn-grid-full">
                    <button class="haraj-btn btn-start" id="update-btn">▶️ تحديث</button>
                </div>
                <div class="btn-grid-full">
                    <button class="haraj-btn btn-myads" id="myads-btn">📋 اعلاناتي</button>
                </div>
                <div class="btn-grid">
                    <button class="haraj-btn btn-like" id="like-btn" disabled>❤️ تفضيل</button>
                    <button class="haraj-btn btn-stop" id="stop-btn" disabled>⏸️ إيقاف</button>
                </div>
                <div class="stats">
                    <div class="stat"><span class="stat-value" id="stat-total">0</span><span class="stat-label">إجمالي</span></div>
                    <div class="stat"><span class="stat-value" id="stat-updated">0</span><span class="stat-label">محدث</span></div>
                    <div class="stat"><span class="stat-value" id="stat-failed">0</span><span class="stat-label">فشل</span></div>
                    <div class="stat"><span class="stat-value" id="stat-remaining">0</span><span class="stat-label">متبقي</span></div>
                </div>
                <div class="progress"><div class="progress-bar" id="progress"></div></div>
                <div class="log" id="log"></div>
            </div>
        `;
        document.body.appendChild(menu);
        
        // Make menu draggable from anywhere on it (buttons, inputs, and the log stay tappable/scrollable)
        makeDraggable(menu, menu);
        
        // Make toggle button draggable
        makeDraggable(toggleBtn, toggleBtn);
        
        // Minimize button handler
        const minimizeBtn = menu.querySelector('.minimize-btn');
        minimizeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            menu.classList.add('minimized');
            toggleBtn.classList.add('show');
            // Sync positions
            toggleBtn.style.top = menu.style.top || '8px';
            toggleBtn.style.left = menu.style.left || 'auto';
            toggleBtn.style.right = menu.style.right || '8px';
        });
        
        // Toggle button handler - show menu
        toggleBtn.addEventListener('click', (e) => {
            menu.classList.remove('minimized');
            toggleBtn.classList.remove('show');
        });
        
        document.getElementById('relogin-btn').onclick = () => window.location.href = 'https://haraj.com.sa/login';
        
        document.querySelectorAll('.speed-btn').forEach(btn => {
            btn.onclick = () => {
                const speed = parseInt(btn.getAttribute('data-speed'));
                CONFIG.adsPerBatch = speed;
                GM_setValue('adsPerBatch', speed);
                document.querySelectorAll('.speed-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                addLog('info', `⚡ السرعة: ${speed} لكل دفعة`);
            };
        });
        
        document.getElementById('update-btn').onclick = loadAndUpdate;
        document.getElementById('myads-btn').onclick = openMyAds;
        document.getElementById('like-btn').onclick = likeAll;
        document.getElementById('stop-btn').onclick = stop;
        
        addLog('info', `🚀 محدث حراج v${VERSION} جاهز!`);
    }

    function shouldIgnoreDragTarget(target) {
        if (!target) return false;
        if (target.tagName === 'BUTTON' || target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') return true;
        if (target.closest && target.closest('.log')) return true;
        return false;
    }

    function makeDraggable(el, dragHandle) {
        const handle = dragHandle || el;
        let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
        let isDragging = false;
        
        // Touch events for mobile
        handle.addEventListener('touchstart', function(e) {
            // Don't drag if touching a button, input, or the scrollable log
            if (shouldIgnoreDragTarget(e.target)) return;
            
            const touch = e.touches[0];
            pos3 = touch.clientX;
            pos4 = touch.clientY;
            isDragging = false;
        }, { passive: true });
        
        handle.addEventListener('touchmove', function(e) {
            // Don't drag if touching a button, input, or the scrollable log
            if (shouldIgnoreDragTarget(e.target)) return;
            
            e.preventDefault();
            isDragging = true;
            
            const touch = e.touches[0];
            const clientX = touch.clientX;
            const clientY = touch.clientY;
            
            pos1 = pos3 - clientX;
            pos2 = pos4 - clientY;
            pos3 = clientX;
            pos4 = clientY;
            
            let newTop = el.offsetTop - pos2;
            let newLeft = el.offsetLeft - pos1;
            
            // Keep within viewport
            newTop = Math.max(0, Math.min(newTop, window.innerHeight - el.offsetHeight));
            newLeft = Math.max(0, Math.min(newLeft, window.innerWidth - el.offsetWidth));
            
            el.style.top = newTop + "px";
            el.style.right = "auto";
            el.style.bottom = "auto";
            el.style.left = newLeft + "px";
        }, { passive: false });
        
        // Mouse events for desktop
        handle.addEventListener('mousedown', function(e) {
            // Don't drag if clicking a button, input, or the scrollable log
            if (shouldIgnoreDragTarget(e.target)) return;
            
            e.preventDefault();
            pos3 = e.clientX;
            pos4 = e.clientY;
            isDragging = false;
            document.addEventListener('mousemove', mouseMove);
            document.addEventListener('mouseup', mouseUp);
        });
        
        function mouseMove(e) {
            e.preventDefault();
            isDragging = true;
            
            pos1 = pos3 - e.clientX;
            pos2 = pos4 - e.clientY;
            pos3 = e.clientX;
            pos4 = e.clientY;
            
            let newTop = el.offsetTop - pos2;
            let newLeft = el.offsetLeft - pos1;
            
            // Keep within viewport
            newTop = Math.max(0, Math.min(newTop, window.innerHeight - el.offsetHeight));
            newLeft = Math.max(0, Math.min(newLeft, window.innerWidth - el.offsetWidth));
            
            el.style.top = newTop + "px";
            el.style.right = "auto";
            el.style.bottom = "auto";
            el.style.left = newLeft + "px";
        }
        
        function mouseUp() {
            document.removeEventListener('mousemove', mouseMove);
            document.removeEventListener('mouseup', mouseUp);
        }
    }

    function extractToken() {
        // Primary source: accessToken lives inside localStorage 'statlogin' now
        try {
            const statlogin = localStorage.getItem('statlogin');
            if (statlogin) {
                const parsed = JSON.parse(statlogin);
                const token = parsed?.state?.accessToken;
                if (token) {
                    const parts = token.split('.');
                    if (parts.length === 3) {
                        CONFIG.token = token;
                        addLog('success', '✓ تم استخراج التوكن من الجلسة');
                    }
                }
            }
        } catch (e) {
            console.error('Failed to extract accessToken from statlogin:', e);
        }
        
        // Extract CLIENT_ID from localStorage meta
        try {
            const meta = localStorage.getItem('meta');
            if (meta) {
                const parsed = JSON.parse(meta);
                if (parsed.state?.clientId) {
                    CONFIG.clientId = parsed.state.clientId;
                    addLog('info', `✓ CLIENT_ID: ${CONFIG.clientId.substring(0, 15)}...`);
                }
            }
        } catch (e) {
            console.error('Failed to extract clientId from meta:', e);
        }
        
        // Fallback to default if not found
        if (!CONFIG.clientId) {
            CONFIG.clientId = '0hxR2sjN-VMMr-QtoI-Sydi-xHqrb6O2M0T8v3';
            addLog('warning', '⚠ استخدام CLIENT_ID الافتراضي');
        }
        
        // Fallback: only check the cookie if statlogin didn't give us a token
        if (!CONFIG.token) {
            const cookieString = document.cookie;
            const accessTokenMatch = cookieString.match(/accessToken=([^;]+)/);
            if (accessTokenMatch) {
                const token = decodeURIComponent(accessTokenMatch[1]);
                const parts = token.split('.');
                if (parts.length === 3) {
                    CONFIG.token = token;
                    addLog('success', '✓ تم استخراج التوكن من الكوكيز');
                }
            }
        }
        
        if (!CONFIG.token) {
            addLog('error', '✗ فشل استخراج التوكن');
            return false;
        }
        
        return true;
    }

    function getMyUsername() {
        try {
            const statlogin = localStorage.getItem('statlogin');
            if (statlogin) {
                const parsed = JSON.parse(statlogin);
                const username = parsed?.state?.username;
                if (username) return username;
            }
        } catch (e) {
            console.error('Failed to extract username from statlogin:', e);
        }
        return null;
    }

    function openMyAds() {
        const username = getMyUsername();
        if (username) {
            window.open(`https://haraj.com.sa/en/users/${username}`, '_blank');
            addLog('info', `فتح إعلاناتي: ${username}`);
        } else {
            addLog('error', 'لم يتم العثور على اسم المستخدم - سجل الدخول أولاً');
        }
    }

    async function loadPosts() {
        addLog('info', 'جاري تحميل الإعلانات...');
        document.getElementById('update-btn').disabled = true;
        
        let previousCount = 0;
        for (let i = 0; i < 50; i++) {
            window.scrollTo(0, document.body.scrollHeight);
            await sleep(1000);
            const loadMoreBtn = document.querySelector('[data-testid="posts-load-more"]');
            if (loadMoreBtn && !loadMoreBtn.disabled) loadMoreBtn.click();
            const currentCount = document.querySelectorAll('[data-test-postid]').length;
            if (currentCount === previousCount) break;
            previousCount = currentCount;
        }
        
        window.scrollTo(0, 0);
        collectPosts();
        document.getElementById('update-btn').disabled = false;
    }
    
    async function loadAndUpdate() {
        await loadPosts();
        if (postIds.length > 0) {
            await startUpdating();
        }
    }

    function collectPosts() {
        postIds = [];
        document.querySelectorAll('[data-test-postid]').forEach(el => {
            const id = el.getAttribute('data-test-postid');
            if (id) postIds.push(parseInt(id));
        });
        
        stats = { total: postIds.length, updated: 0, failed: 0 };
        currentIndex = 0;
        updateStats();
        
        if (postIds.length > 0) {
            addLog('success', `تم تحميل ${postIds.length} إعلان`);
            document.getElementById('like-btn').disabled = false;
        } else {
            addLog('error', 'لم يتم العثور على إعلانات');
        }
    }

    async function startUpdating() {
        if (!extractToken()) {
            addLog('error', 'فشل استخراج التوكن');
            return;
        }
        
        hideTokenWarning();
        isRunning = true;
        document.getElementById('update-btn').disabled = true;
        document.getElementById('stop-btn').disabled = false;
        document.getElementById('like-btn').disabled = true;
        addLog('info', 'بدء التحديث...');
        await updateBatch();
    }

    async function updateBatch() {
        if (!isRunning || currentIndex >= postIds.length) {
            if (currentIndex >= postIds.length) {
                addLog('success', '✅ اكتمل التحديث!');
                stop();
            }
            return;
        }

        const batch = postIds.slice(currentIndex, currentIndex + CONFIG.adsPerBatch);
        for (let id of batch) {
            if (!isRunning) break;
            await updatePost(id);
        }

        currentIndex += CONFIG.adsPerBatch;
        updateStats();

        if (isRunning && currentIndex < postIds.length) {
            setTimeout(() => updateBatch(), CONFIG.updateInterval);
        } else if (currentIndex >= postIds.length) {
            addLog('success', '✅ اكتمل التحديث!');
            stop();
        }
    }

    async function updatePost(id) {
        try {
            const lang = document.documentElement.lang || 'ar';
            const url = `${CONFIG.graphqlEndpoint}?queryName=updatePost&lang=${lang}&clientId=${CONFIG.clientId}&version=N0.0.1`;
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': '*/*',
                    'Origin': 'https://haraj.com.sa',
                    'Referer': 'https://haraj.com.sa/'
                },
                credentials: 'include',
                body: JSON.stringify({
                    query: `mutation updatePost($token: String!, $id: Int!) {\n updatePost(token: $token, id: $id) {\n status\n notValidReason\n }\n}`,
                    variables: { token: CONFIG.token, id: id }
                })
            });

            const data = await response.json();
            
            if (data.data?.updatePost?.status === true) {
                stats.updated++;
                addLog('success', `✓ #${id}`);
                tokenExpiredCount = 0;
            } else {
                stats.failed++;
                const reason = data.data?.updatePost?.notValidReason || 'فشل';
                
                if (reason === 'لم يتم تسجيل الدخول') {
                    tokenExpiredCount++;
                    addLog('error', `✗ #${id}: جلسة منتهية (${tokenExpiredCount}/3)`);
                    if (tokenExpiredCount >= 3) {
                        addLog('error', '🛑 مشكلة سيرفر - الجلسة منتهية');
                        addLog('info', '💡 إعادة الدخول قد تحل المشكلة مؤقتاً');
                        showTokenWarning();
                        stop();
                    }
                } else {
                    addLog('error', `✗ #${id}: ${reason}`);
                }
            }
        } catch (error) {
            stats.failed++;
            addLog('error', `✗ #${id}`);
        }
    }
    
    function showTokenWarning() {
        document.getElementById('token-warning').classList.add('show');
        document.getElementById('relogin-btn').classList.add('show');
    }
    
    function hideTokenWarning() {
        document.getElementById('token-warning').classList.remove('show');
        document.getElementById('relogin-btn').classList.remove('show');
        tokenExpiredCount = 0;
    }

    async function likeAll() {
        if (!extractToken()) {
            addLog('error', 'فشل استخراج التوكن');
            return;
        }
        
        isRunning = true;
        document.getElementById('like-btn').disabled = true;
        document.getElementById('update-btn').disabled = true;
        document.getElementById('stop-btn').disabled = false;
        addLog('info', 'بدء التفضيل...');
        
        for (let i = 0; i < postIds.length; i++) {
            if (!isRunning) break;
            await likePost(postIds[i]);
            updateStats();
            await sleep(CONFIG.updateInterval);
        }
        
        addLog('success', '✅ اكتمل التفضيل!');
        stop();
    }

    async function likePost(id) {
        try {
            const response = await fetch(CONFIG.graphqlEndpoint + `?queryName=submitLike&clientId=${CONFIG.clientId}&version=N0.0.1`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include',
                body: JSON.stringify({
                    query: `mutation { submitLike(token: "${CONFIG.token}", id: ${id}) }`,
                })
            });
            
            const data = await response.json();
            if (data.data?.submitLike) {
                stats.updated++;
                addLog('success', `❤️ #${id}`);
            }
        } catch (error) {
            stats.failed++;
        }
    }

    function stop() {
        isRunning = false;
        document.getElementById('update-btn').disabled = false;
        document.getElementById('stop-btn').disabled = true;
        document.getElementById('like-btn').disabled = false;
    }

    function updateStats() {
        document.getElementById('stat-total').textContent = stats.total;
        document.getElementById('stat-updated').textContent = stats.updated;
        document.getElementById('stat-failed').textContent = stats.failed;
        document.getElementById('stat-remaining').textContent = Math.max(0, stats.total - currentIndex);
        const progress = stats.total > 0 ? (currentIndex / stats.total) * 100 : 0;
        document.getElementById('progress').style.width = progress + '%';
    }

    function addLog(type, msg) {
        const log = document.getElementById('log');
        if (!log) return;
        const entry = document.createElement('div');
        entry.className = `log-entry log-${type}`;
        const time = new Date().toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        entry.innerHTML = `<span class="log-time">${time}</span> ${msg}`;
        log.insertBefore(entry, log.firstChild);
        while (log.children.length > 100) log.removeChild(log.lastChild);
    }

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    // ========== AI HELPER FUNCTIONALITY ==========
    let aiChatMessages = [];
    let currentTextarea = null;
    let suggestedText = '';
    
    function injectAIButton() {
        const textarea = document.querySelector('textarea[data-testid="add-post-bodyText"]');
        if (!textarea || document.getElementById('ai-helper-btn')) return;
        
        // Create AI button
        const aiBtn = document.createElement('div');
        aiBtn.id = 'ai-helper-btn';
        aiBtn.className = 'ai-helper-btn';
        aiBtn.innerHTML = '🤖';
        aiBtn.title = 'مساعد AI';
        
        // Create AI chat panel
        const chatPanel = createAIChatPanel();
        
        // Insert button and panel (fixed-position, attached to body so they can be dragged anywhere)
        document.body.appendChild(aiBtn);
        document.body.appendChild(chatPanel);
        
        // Make both draggable, same as the main menu/toggle button
        makeDraggable(aiBtn, aiBtn);
        makeDraggable(chatPanel, chatPanel.querySelector('.ai-chat-header'));
        
        // Button click handler
        aiBtn.addEventListener('click', () => {
            currentTextarea = textarea;
            chatPanel.classList.toggle('show');
            if (chatPanel.classList.contains('show')) {
                addAIMessage('system', 'مرحباً! أنا هنا لمساعدتك في تحسين نص إعلانك. اكتب ما تريد تغييره أو تحسينه.');
            }
        });
    }
    
    function createAIChatPanel() {
        const panel = document.createElement('div');
        panel.id = 'ai-chat-panel';
        panel.innerHTML = `
            <div class="ai-chat-header">
                <h4>🤖 مساعد الذكاء الاصطناعي</h4>
                <button class="ai-close-btn">×</button>
            </div>
            <div class="ai-chat-messages" id="ai-messages"></div>
            <div class="ai-chat-input-area">
                <div class="ai-input-wrapper">
                    <input type="text" class="ai-chat-input" id="ai-input" placeholder="اكتب رسالتك هنا..." />
                    <button class="ai-send-btn" id="ai-send-btn">📤</button>
                </div>
            </div>
        `;
        
        // Close button handler
        panel.querySelector('.ai-close-btn').addEventListener('click', () => {
            panel.classList.remove('show');
        });
        
        // Send button handler
        const input = panel.querySelector('#ai-input');
        const sendBtn = panel.querySelector('#ai-send-btn');
        
        sendBtn.addEventListener('click', () => sendAIMessage(input));
        input.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendAIMessage(input);
        });
        
        return panel;
    }
    
    function addAIMessage(role, content, showPreview = false) {
        const messagesContainer = document.getElementById('ai-messages');
        if (!messagesContainer) return;
        
        const messageDiv = document.createElement('div');
        messageDiv.className = `ai-message ${role}`;
        
        if (showPreview && role === 'assistant') {
            const textNode = document.createElement('div');
            textNode.textContent = content;
            
            const previewBox = document.createElement('div');
            previewBox.className = 'ai-preview-box';
            previewBox.textContent = suggestedText;
            
            const actionBtns = document.createElement('div');
            actionBtns.className = 'ai-action-btns';
            
            const acceptBtn = document.createElement('button');
            acceptBtn.className = 'ai-action-btn accept';
            acceptBtn.textContent = '✓ قبول التغييرات';
            acceptBtn.addEventListener('click', acceptAIText);
            
            const declineBtn = document.createElement('button');
            declineBtn.className = 'ai-action-btn decline';
            declineBtn.textContent = '✗ رفض';
            declineBtn.addEventListener('click', declineAIText);
            
            actionBtns.appendChild(acceptBtn);
            actionBtns.appendChild(declineBtn);
            
            messageDiv.appendChild(textNode);
            messageDiv.appendChild(previewBox);
            messageDiv.appendChild(actionBtns);
        } else {
            messageDiv.textContent = content;
        }
        
        messagesContainer.appendChild(messageDiv);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
    
    async function sendAIMessage(input) {
        const message = input.value.trim();
        if (!message || !currentTextarea) return;
        
        const sendBtn = document.getElementById('ai-send-btn');
        sendBtn.disabled = true;
        
        // Add user message
        addAIMessage('user', message);
        aiChatMessages.push({ role: 'user', content: message });
        input.value = '';
        
        // Add loading message
        addAIMessage('system', 'جاري التفكير...');
        
        try {
            // Get current textarea content
            const currentContent = currentTextarea.value;
            
            // Build context for AI
            const systemPrompt = `أنت مساعد ذكي متخصص في تحسين إعلانات حراج. النص الحالي في الإعلان هو:\n"${currentContent}"\n\nساعد المستخدم في تحسين أو تعديل هذا النص حسب طلبه. قدم النص المحسّن كاملاً بدون شرح إضافي.`;
            
            const messages = [
                { role: 'system', content: systemPrompt },
                ...aiChatMessages
            ];
            
            // Call OpenRouter API using fetch (works without Tampermonkey APIs)
            fetch(OPENROUTER_CONFIG.apiUrl, {
                method: 'POST',
                headers: {
                    'Authorization': `Bearer ${OPENROUTER_CONFIG.apiKey}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model: OPENROUTER_CONFIG.model,
                    messages: messages
                })
            })
            .then(response => response.json())
            .then(data => {
                const messagesContainer = document.getElementById('ai-messages');
                
                if (messagesContainer && messagesContainer.lastChild && messagesContainer.lastChild.classList.contains('system')) {
                    messagesContainer.removeChild(messagesContainer.lastChild);
                }
                
                if (data.error) {
                    const errorMsg = data.error.message || 'خطأ غير معروف';
                    console.error('API Error:', data);
                    addAIMessage('system', `❌ خطأ: ${errorMsg}`);
                    sendBtn.disabled = false;
                    return;
                }
                
                const aiResponse = data.choices[0].message.content;
                suggestedText = aiResponse;
                aiChatMessages.push({ role: 'assistant', content: aiResponse });
                addAIMessage('assistant', 'إليك النص المحسّن:', true);
                sendBtn.disabled = false;
            })
            .catch(error => {
                console.error('AI Error:', error);
                const messagesContainer = document.getElementById('ai-messages');
                if (messagesContainer && messagesContainer.lastChild && messagesContainer.lastChild.classList.contains('system')) {
                    messagesContainer.removeChild(messagesContainer.lastChild);
                }
                addAIMessage('system', 'عذراً، حدث خطأ في الاتصال.');
                sendBtn.disabled = false;
            });
            
        } catch (error) {
            console.error('AI Error:', error);
            addAIMessage('system', 'عذراً، حدث خطأ غير متوقع. حاول مرة أخرى.');
            sendBtn.disabled = false;
        }
    }
    
    // Accept/Decline functions
    function acceptAIText() {
        if (currentTextarea && suggestedText) {
            currentTextarea.value = suggestedText;
            // Trigger change event
            currentTextarea.dispatchEvent(new Event('input', { bubbles: true }));
            currentTextarea.dispatchEvent(new Event('change', { bubbles: true }));
            addAIMessage('system', '✓ تم تطبيق التغييرات بنجاح!');
            suggestedText = '';
        }
    }
    
    function declineAIText() {
        addAIMessage('system', 'تم رفض التغييرات. يمكنك طلب تعديل آخر.');
        suggestedText = '';
    }
    
    // Watch for textarea to appear
    function watchForTextarea() {
        const observer = new MutationObserver(() => {
            injectAIButton();
        });
        
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
        
        // Try immediately
        injectAIButton();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
            createMenu();
            watchForTextarea();
        });
    } else {
        createMenu();
        watchForTextarea();
    }
})();
