        }
        .log::-webkit-scrollbar { width: 8px; }
        .log::-webkit-scrollbar-track { background: rgba(0,0,0,0.3); border-radius: 4px; }
        .log::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.4); border-radius: 4px; }
        .log-entry {
            padding: 7px 10px; margin-bottom: 5px; border-radius: 5px;
            border-left: 4px solid transparent; line-height: 1.5;
        }
        .log-success { background: rgba(16,185,129,0.2); border-left-color: #10b981; }
        .log-error { background: rgba(239,68,68,0.2); border-left-color: #ef4444; }
        .log-info { background: rgba(59,130,246,0.2); border-left-color: #3b82f6; }
        .log-warning { background: rgba(245,158,11,0.2); border-left-color: #f59e0b; }
        .log-time { opacity: 0.7; font-size: 10px; margin-left: 8px; }
        .token-warning {
            background: rgba(239,68,68,0.25); border: 2px solid #ef4444; border-radius: 8px;
            padding: 12px; margin-bottom: 14px; text-align: center;
            font-size: 13px; font-weight: 700; display: none;
        }
        .token-warning.show { display: block; animation: pulse 2s infinite; }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.02); }
        }
        .btn-relogin {
            background: linear-gradient(135deg, #ef4444, #dc2626); color: white;
            width: 100%; padding: 12px; border: none; border-radius: 8px;
            font-size: 14px; font-weight: 700; cursor: pointer; margin-bottom: 14px;
            display: none; box-shadow: 0 4px 12px rgba(239,68,68,0.4);
        }
        .btn-relogin.show { display: block; }
        .btn-relogin:hover {
            transform: translateY(-2px); box-shadow: 0 6px 16px rgba(239,68,68,0.5);
        }
        .minimized #haraj-content { display: none; }
        
        /* AI Chat Styles */
        .ai-helper-btn {
            position: absolute;
            bottom: 8px;
            left: 8px;
            width: 40px;
            height: 40px;
            background: linear-gradient(145deg, #10b981, #059669);
            border: 2px solid rgba(255,255,255,0.4);
            border-radius: 50%;
            box-shadow: 0 4px 12px rgba(16,185,129,0.4);
            cursor: pointer;
            z-index: 999997;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            transition: transform 0.2s ease;
        }
        .ai-helper-btn:hover {
            transform: scale(1.1);
        }
        
        #ai-chat-panel {
            position: fixed;
            bottom: 60px;
            left: 20px;
            width: 400px;
            max-height: 70vh;
            background: linear-gradient(145deg, #10b981 0%, #059669 100%);
            border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.6);
            z-index: 999998;
            display: none;
            flex-direction: column;
            border: 2px solid rgba(255,255,255,0.2);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #ai-chat-panel.show {
            display: flex;
        }
        
        .ai-chat-header {
            background: rgba(0,0,0,0.3);
            padding: 12px 14px;
            border-radius: 10px 10px 0 0;
            border-bottom: 2px solid rgba(255,255,255,0.15);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ai-chat-header h4 {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: white;
        }
        .ai-close-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .ai-close-btn:hover {
            background: rgba(255,255,255,0.3);
        }
        
        .ai-chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
            direction: rtl;
        }
        .ai-chat-messages::-webkit-scrollbar { width: 8px; }
        .ai-chat-messages::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
        .ai-chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 4px; }
        
        .ai-message {
