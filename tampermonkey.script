        .btn-start { background: linear-gradient(135deg, #10b981, #059669); color: white; }
        .btn-like { background: linear-gradient(135deg, #f59e0b, #d97706); color: white; }
        .btn-stop { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; }
        .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 14px 0; }
        .stat {
            background: rgba(255,255,255,0.15); padding: 12px; border-radius: 8px;
            text-align: center; font-size: 12px; border: 1px solid rgba(255,255,255,0.12);
        }
        .stat-value { font-size: 26px; font-weight: 800; display: block; margin-bottom: 3px; }
        .stat-label { font-size: 11px; opacity: 0.9; font-weight: 600; }
        .progress {
            width: 100%; height: 10px; background: rgba(0,0,0,0.35); border-radius: 5px;
            overflow: hidden; margin: 14px 0; border: 1px solid rgba(255,255,255,0.15);
        }
        .progress-bar {
            height: 100%; background: linear-gradient(90deg, #10b981, #34d399, #10b981);
            background-size: 200% 100%; transition: width 0.3s;
            box-shadow: 0 0 12px rgba(16,185,129,0.6); animation: shimmer 2s infinite;
        }
        @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
        .log {
            background: rgba(0,0,0,0.4); border-radius: 8px; padding: 12px;
            max-height: 200px; overflow-y: auto; font-size: 11px;
