// ==UserScript==
// @name         Haraj Auto Updater - محدث حراج التلقائي
// @namespace    http://tampermonkey.net/
// @version      3.2.0
// @description  Auto update Haraj ads with configurable speed - تحديث إعلانات حراج تلقائياً
// @author       You
// @match        https://haraj.com.sa/*
// @match        https://www.haraj.com.sa/*
// @match        https://haraj.com/*
// @match        https://www.haraj.com/*
// @grant        GM_xmlhttpRequest
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_addStyle
// @grant        GM_info
// @updateURL    https://raw.githubusercontent.com/mohammmedVDX/harajupdater/refs/heads/main/tampermonkey.script
// @downloadURL  https://raw.githubusercontent.com/mohammmedVDX/harajupdater/refs/heads/main/tampermonkey.script
// @connect      raw.githubusercontent.com
// @connect      api.haraj.com.sa
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // Configuration
    const CONFIG = {
        updateInterval: GM_getValue('updateInterval', 1000), // milliseconds between updates
        adsPerBatch: GM_getValue('adsPerBatch', 6), // ads to update per batch
        autoStart: GM_getValue('autoStart', false),
        token: null,
        graphqlEndpoint: 'https://graphql.haraj.com.sa/',
        quickReplies: GM_getValue('quickReplies', [])
    };

    // State
    let isRunning = false;
    let isLiking = false;
    let currentIndex = 0;
    let postIds = [];
    let postsData = []; // Store full post data including images and titles
    let stats = {
        total: 0,
        updated: 0,
        failed: 0,
        skipped: 0,
        liked: 0
    };

    // Expose functions to window IMMEDIATELY (before anything else)
    window.harajUpdater = {
        removeQuickReply: function(index) {
            try {
                CONFIG.quickReplies.splice(index, 1);
                GM_setValue('quickReplies', CONFIG.quickReplies);
                renderQuickReplyList();
                renderQuickReplyPanel();
                addLog('info', 'تم حذف الرد السريع');
            } catch (error) {
                console.error('Error removing quick reply:', error);
            }
        },
        insertQuickReply: function(index) {
            try {
                const reply = CONFIG.quickReplies[index];
                if (!reply) return;

                // Try to find chat textarea
                const textarea = document.querySelector('textarea[id*="chat"], textarea[placeholder*="رسالة"], #chat-textbox');
                
                if (textarea) {
                    textarea.value = reply;
                    textarea.focus();
                    
                    // Trigger input event to update any React/Vue state
                    const event = new Event('input', { bubbles: true });
                    textarea.dispatchEvent(event);
                    
                    console.log('✅ Quick reply inserted');
                } else {
                    // Copy to clipboard as fallback
                    navigator.clipboard.writeText(reply).then(() => {
                        console.log('✅ Quick reply copied to clipboard');
                    });
                }
            } catch (error) {
                console.error('Error inserting quick reply:', error);
            }
        },
        sendQuickReply: async function(text) {
            try {
                // Find the chat textarea
                const textarea = document.querySelector('textarea[id*="chat"]') || 
                                document.querySelector('textarea[placeholder*="رسالة"]') ||
                                document.querySelector('#chat-textbox');
                
                if (!textarea) {
                    alert('❌ لم يتم العثور على مربع المحادثة');
                    return;
                }
                
                // Insert text
                textarea.value = text;
                textarea.focus();
                
                // Trigger input event (for React/Vue)
                const inputEvent = new Event('input', { bubbles: true });
                textarea.dispatchEvent(inputEvent);
                
                // Trigger change event
                const changeEvent = new Event('change', { bubbles: true });
                textarea.dispatchEvent(changeEvent);
                
                // Wait a bit for the UI to update
                await new Promise(resolve => setTimeout(resolve, 100));
                
                // Try to find and click the send button
                const sendButton = document.querySelector('button[type="submit"]') ||
                                  document.querySelector('button[aria-label*="send"]') ||
                                  document.querySelector('button[aria-label*="إرسال"]') ||
                                  Array.from(document.querySelectorAll('button')).find(btn => {
                                      const text = btn.textContent.toLowerCase();
                                      return text.includes('send') || text.includes('إرسال');
                                  });
                
                if (sendButton && !sendButton.disabled) {
                    sendButton.click();
                    console.log('✅ Message sent successfully');
                } else {
                    // If no send button found, just show the text is ready
                    console.log('⚠️ Text inserted, please press Enter or click Send');
                    alert('✅ تم إدراج النص. اضغط Enter أو زر الإرسال');
                }
            } catch (error) {
                console.error('Error sending message:', error);
                alert('❌ حدث خطأ أثناء إرسال الرسالة');
            }
        }
    };

    // Add CSS styles
    GM_addStyle(`
        #haraj-updater-menu {
            position: fixed;
            top: 80px;
            right: 15px;
            width: 320px;
            max-width: 90vw;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
