// ==UserScript==
// @name         Haraj Auto Updater - محدث حراج التلقائي
// @namespace    http://tampermonkey.net/
// @version      6.2.5
// @description  Auto update Haraj ads - تحديث إعلانات حراج تلقائياً
// @author       You
// @match        https://haraj.com.sa/*
// @match        https://www.haraj.com.sa/*
// @match        https://haraj.com/*
// @match        https://www.haraj.com/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    const VERSION = '6.2.5';
    
    // OpenRouter API Configuration (obfuscated key, no specific @connect needed)
    const OPENROUTER_CONFIG = {
        apiKey: atob('c2stb3ItdjEtZThlOGNjZjMyOTYxMGRiYjA4ODMxYzExYmU5YWY2ZThmMWFiN2UyYzgyN2IzYjc2YzQ5MzhiYmE4MTY5NGVjOA=='),
        apiUrl: 'https://openrouter.ai/api/v1/chat/completions',
        model: 'google/gemma-4-31b-it:free'
    };
    
    const CONFIG = {
        updateInterval: GM_getValue('updateInterval', 1000),
        adsPerBatch: GM_getValue('adsPerBatch', 6),
        token: null,
        clientId: null,
        graphqlEndpoint: 'https://graphql.haraj.com.sa/'
    };

    let isRunning = false;
    let currentIndex = 0;
    let postIds = [];
    let stats = { total: 0, updated: 0, failed: 0 };
    let tokenExpiredCount = 0;

    GM_addStyle(`
        #haraj-menu {
            position: fixed; top: 20px; right: 20px; width: 340px;
            background: linear-gradient(145deg, #667eea 0%, #764ba2 100%);
            border-radius: 12px; box-shadow: 0 15px 50px rgba(0,0,0,0.5); z-index: 999999;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: white;
            direction: rtl; border: 3px solid rgba(255,255,255,0.15);
        }
        #haraj-header {
            background: rgba(0,0,0,0.3); padding: 16px; cursor: move;
            display: flex; justify-content: space-between; align-items: center;
            border-radius: 10px 10px 0 0; border-bottom: 2px solid rgba(255,255,255,0.1);
        }
        #haraj-header h3 {
            margin: 0; font-size: 18px; font-weight: 700; letter-spacing: 0.5px;
