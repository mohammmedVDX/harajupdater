    // Create menu
    function createMenu() {
        const menu = document.createElement('div');
        menu.id = 'haraj-updater-menu';
        menu.innerHTML = `
            <div id="haraj-updater-header">
                <h3>
                    <span>🔄</span>
                    <span>محدث حراج</span>
                    <span class="token-status invalid" id="token-status" title="حالة التوكن"></span>
                </h3>
                <button id="haraj-updater-minimize">−</button>
            </div>
            <div id="haraj-updater-content">
                <div class="updater-section">
                    <label>⚡ السرعة</label>
                    <div class="speed-presets">
                        <button class="speed-preset" data-speed="3">بطيء</button>
                        <button class="speed-preset active" data-speed="6">متوسط</button>
                        <button class="speed-preset" data-speed="10">سريع</button>
                    </div>
                </div>

                <button class="updater-button refresh-token" id="refresh-token-btn">
                    🔄 تحديث التوكن
                </button>

                <button class="updater-button load" id="load-posts-btn">
                    📋 تحميل الإعلانات
                </button>

                <button class="updater-button start" id="start-btn" disabled>
                    ▶️ بدء التحديث
                </button>

                <button class="updater-button like" id="like-all-btn" disabled>
                    ❤️ تفضيل الكل
                </button>

                <button class="updater-button stop" id="stop-btn" disabled>
                    ⏸️ إيقاف
                </button>

                <button class="updater-button load" id="quick-reply-btn">
                    💬 الردود السريعة
                </button>

                <div class="stats-grid">
                    <div class="stat-box">
                        <span class="stat-value" id="stat-total">0</span>
                        <span class="stat-label">إجمالي</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-value" id="stat-updated">0</span>
                        <span class="stat-label">محدث</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-value" id="stat-failed">0</span>
                        <span class="stat-label">فشل</span>
                    </div>
                    <div class="stat-box">
                        <span class="stat-value" id="stat-remaining">0</span>
                        <span class="stat-label">متبقي</span>
                    </div>
                </div>

                <div class="progress-bar">
                    <div class="progress-fill" id="progress-fill" style="width: 0%"></div>
                </div>

                <div class="log-container" id="log-container"></div>
            </div>
        `;

        document.body.appendChild(menu);
        makeDraggable(menu);
        attachEventListeners();
        createQuickReplyUI();
    }

    // Make menu draggable
    function makeDraggable(element) {
        const header = element.querySelector('#haraj-updater-header');
        let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;

        header.onmousedown = dragMouseDown;

        function dragMouseDown(e) {
            e.preventDefault();
            pos3 = e.clientX;
            pos4 = e.clientY;
            document.onmouseup = closeDragElement;
            document.onmousemove = elementDrag;
        }

        function elementDrag(e) {
            e.preventDefault();
            pos1 = pos3 - e.clientX;
            pos2 = pos4 - e.clientY;
            pos3 = e.clientX;
            pos4 = e.clientY;
            element.style.top = (element.offsetTop - pos2) + "px";
            element.style.right = "auto";
            element.style.left = (element.offsetLeft - pos1) + "px";
        }

        function closeDragElement() {
            document.onmouseup = null;
            document.onmousemove = null;
        }
    }

    // Attach event listeners
    function attachEventListeners() {
        // Minimize button
        document.getElementById('haraj-updater-minimize').addEventListener('click', () => {
            const menu = document.getElementById('haraj-updater-menu');
            menu.classList.toggle('minimized');
            const btn = document.getElementById('haraj-updater-minimize');
            btn.textContent = menu.classList.contains('minimized') ? '+' : '−';
        });

        // Speed presets
        document.querySelectorAll('.speed-preset').forEach(btn => {
            btn.addEventListener('click', (e) => {
                document.querySelectorAll('.speed-preset').forEach(b => b.classList.remove('active'));
                e.target.classList.add('active');
                const speed = parseInt(e.target.dataset.speed);
                CONFIG.adsPerBatch = speed;
                GM_setValue('adsPerBatch', speed);
                addLog('info', `تم تغيير السرعة إلى ${speed} إعلانات/دفعة`);
            });
        });

        // Refresh token button
        document.getElementById('refresh-token-btn').addEventListener('click', refreshToken);

        // Load posts button
        document.getElementById('load-posts-btn').addEventListener('click', loadPosts);

        // Start button
        document.getElementById('start-btn').addEventListener('click', startUpdating);

        // Like all button
        document.getElementById('like-all-btn').addEventListener('click', likeAllAds);

        // Stop button
        document.getElementById('stop-btn').addEventListener('click', stopUpdating);

        // Quick reply button
        document.getElementById('quick-reply-btn').addEventListener('click', openQuickReplyModal);
    }

    // Extract token from page
    function extractToken() {
        try {
            // Method 1: Direct cookie parsing for accessToken and refreshToken
            const cookieString = document.cookie;
            console.log('🔍 Raw cookies:', cookieString);
            
            // Parse cookies properly
            const cookies = {};
            cookieString.split(';').forEach(cookie => {
                const [name, ...rest] = cookie.trim().split('=');
                if (name && rest.length > 0) {
                    cookies[name] = rest.join('='); // Handle values with = in them
                }
            });
            
            console.log('📦 Parsed cookies:', Object.keys(cookies));
            
            // Try accessToken first
            if (cookies['accessToken']) {
                console.log('✅ accessToken found, length:', cookies['accessToken'].length);
                if (cookies['accessToken'].length > 20) {
                    CONFIG.token = cookies['accessToken'];
                    addLog('success', 'تم استخراج التوكن من accessToken');
                    console.log('✅ Token set:', CONFIG.token.substring(0, 30) + '...');
                    return true;
                }
            } else {
                console.log('❌ accessToken not found in cookies');
            }
            
            // Try refreshToken
            if (cookies['refreshToken']) {
                console.log('✅ refreshToken found, length:', cookies['refreshToken'].length);
                if (cookies['refreshToken'].length > 20) {
                    CONFIG.token = cookies['refreshToken'];
                    addLog('success', 'تم استخراج التوكن من refreshToken');
                    console.log('✅ Token set:', CONFIG.token.substring(0, 30) + '...');
                    return true;
                }
            } else {
                console.log('❌ refreshToken not found in cookies');
            }
            
            // Method 2: Check all cookies for JWT tokens (has 3 parts separated by dots)
            console.log('🔍 Scanning all cookies for JWT tokens...');
            for (const [name, value] of Object.entries(cookies)) {
                console.log(`  - ${name}: ${value.substring(0, 20)}... (length: ${value.length}, dots: ${value.split('.').length - 1})`);
                if (value && value.length > 20 && value.split('.').length === 3) {
                    CONFIG.token = value;
                    addLog('success', `تم استخراج التوكن من ${name}`);
                    console.log('✅ Token set from', name, ':', value.substring(0, 30) + '...');
                    return true;
                }
            }

            // Method 3: Try to get token from localStorage with various key names
            const possibleKeys = ['token', 'authToken', 'auth_token', 'userToken', 'user_token', 'accessToken', 'access_token'];
            
            for (let key of possibleKeys) {
                const tokenData = localStorage.getItem(key);
                if (tokenData) {
                    try {
                        const parsed = JSON.parse(tokenData);
                        CONFIG.token = parsed.token || parsed.accessToken || parsed.access_token || parsed;
                        if (CONFIG.token && typeof CONFIG.token === 'string' && CONFIG.token.length > 10) {
                            addLog('success', 'تم استخراج التوكن من localStorage');
                            return true;
                        }
                    } catch {
                        // If not JSON, use as is
                        if (tokenData.length > 10) {
                            CONFIG.token = tokenData;
                            addLog('success', 'تم استخراج التوكن من localStorage');
                            return true;
                        }
                    }
                }
            }

            // Method 4: Check all localStorage items for JWT-like tokens
            for (let i = 0; i < localStorage.length; i++) {
                const key = localStorage.key(i);
                const value = localStorage.getItem(key);
                
                // Check if value looks like a JWT token (has two dots)
                if (value && typeof value === 'string' && value.split('.').length === 3) {
                    CONFIG.token = value;
                    addLog('success', `تم استخراج التوكن من ${key}`);
                    return true;
                }
                
                // Check if value is JSON containing a token
                try {
                    const parsed = JSON.parse(value);
                    if (parsed.token || parsed.accessToken || parsed.access_token) {
                        CONFIG.token = parsed.token || parsed.accessToken || parsed.access_token;
                        if (CONFIG.token && typeof CONFIG.token === 'string' && CONFIG.token.length > 10) {
                            addLog('success', `تم استخراج التوكن من ${key}`);
                            return true;
                        }
                    }
                } catch {
                    // Not JSON, continue
                }
            }

            // Method 5: Try to extract from sessionStorage
            for (let i = 0; i < sessionStorage.length; i++) {
                const key = sessionStorage.key(i);
                const value = sessionStorage.getItem(key);
                
                // Check if value looks like a JWT token
                if (value && typeof value === 'string' && value.split('.').length === 3) {
                    CONFIG.token = value;
                    addLog('success', `تم استخراج التوكن من sessionStorage: ${key}`);
                    return true;
                }
                
                // Check if value is JSON containing a token
                try {
                    const parsed = JSON.parse(value);
                    if (parsed.token || parsed.accessToken || parsed.access_token) {
                        CONFIG.token = parsed.token || parsed.accessToken || parsed.access_token;
                        if (CONFIG.token && typeof CONFIG.token === 'string' && CONFIG.token.length > 10) {
                            addLog('success', `تم استخراج التوكن من sessionStorage: ${key}`);
                            return true;
                        }
                    }
                } catch {
                    // Not JSON, continue
                }
            }

            addLog('error', 'لم يتم العثور على التوكن. الرجاء تسجيل الدخول أو إدخال التوكن يدوياً');
            console.log('=== للمساعدة في إيجاد التوكن ===');
            console.log('Cookies:', document.cookie);
            console.log('localStorage keys:', Object.keys(localStorage));
            console.log('sessionStorage keys:', Object.keys(sessionStorage));
            return false;
        } catch (e) {
            console.error('Error extracting token:', e);
            addLog('error', `خطأ في استخراج التوكن: ${e.message}`);
            return false;
        }
    }

    // Update token status indicator
    function updateTokenStatus(isValid) {
        const statusEl = document.getElementById('token-status');
        if (statusEl) {
            if (isValid) {
                statusEl.classList.remove('invalid');
                statusEl.classList.add('valid');
                statusEl.title = 'التوكن صالح ✓';
            } else {
                statusEl.classList.remove('valid');
                statusEl.classList.add('invalid');
                statusEl.title = 'التوكن غير صالح ✗';
            }
        }
    }

    // Validate token by making a test API call
    async function validateToken() {
        if (!CONFIG.token) {
            updateTokenStatus(false);
            return false;
        }

        try {
            addLog('info', 'جاري التحقق من صلاحية التوكن...');
            
            // Make a simple test request - just try to update a non-existent post
            // This will tell us if the token is valid without actually updating anything
            const response = await fetch(CONFIG.graphqlEndpoint + '?queryName=validateToken&clientId=ymZn1c5V-kFw1-HIfT-5zEd-mEHP5dmkhQ6Rv3&version=N0.0.1', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    query: `mutation {
                        updatePost(token: "${CONFIG.token}", id: 999999999) {
                            status
                            notValidReason
                        }
                    }`
                })
            });

            if (!response.ok) {
                addLog('error', '❌ فشل الاتصال بالخادم');
                updateTokenStatus(false);
                return false;
            }

            const text = await response.text();
            if (!text) {
                addLog('error', '❌ استجابة فارغة من الخادم');
                updateTokenStatus(false);
                return false;
            }

            const data = JSON.parse(text);
            
            // Check if we got "not logged in" error
            if (data.errors && data.errors.some(e => e.message && e.message.includes('لم يتم تسجيل الدخول'))) {
                addLog('error', '❌ التوكن غير صالح - لم يتم تسجيل الدخول');
                updateTokenStatus(false);
                return false;
            }
            
            // If we got any response without "not logged in" error, token is valid
            addLog('success', '✅ التوكن صالح ويعمل بشكل صحيح');
            updateTokenStatus(true);
            return true;
        } catch (error) {
            console.error('Token validation error:', error);
            addLog('error', 'فشل التحقق من التوكن');
            updateTokenStatus(false);
            return false;
        }
    }

    // Refresh token
    async function refreshToken() {
        addLog('info', 'جاري تحديث التوكن...');
        CONFIG.token = null;
        updateTokenStatus(false);
        
        if (extractToken()) {
            // Validate the new token
            await validateToken();
        } else {
            addLog('error', 'فشل في استخراج التوكن. الرجاء تسجيل الدخول مرة أخرى');
        }
    }

    // Load posts from page
    async function loadPosts() {
        addLog('info', 'جاري تحميل جميع الإعلانات...');
        document.getElementById('load-posts-btn').disabled = true;
        document.getElementById('load-posts-btn').textContent = '⏳ جاري التحميل...';
        
        let previousCount = 0;
        let currentCount = 0;
        let attempts = 0;
        const maxAttempts = 50; // Maximum attempts to prevent infinite loop
        
        // Function to scroll to bottom
        const scrollToBottom = () => {
            window.scrollTo(0, document.body.scrollHeight);
        };
        
        // Function to scroll to top
        const scrollToTop = () => {
            window.scrollTo(0, 0);
        };
        
        // Function to click load more button
        const clickLoadMore = () => {
            const loadMoreBtn = document.querySelector('[data-testid="posts-load-more"]');
            if (loadMoreBtn && !loadMoreBtn.disabled) {
                loadMoreBtn.click();
                return true;
            }
            return false;
        };
        
        // Function to count current posts
        const countPosts = () => {
            return document.querySelectorAll('[data-test-postid]').length;
        };
        
        // Start from top
        scrollToTop();
        await sleep(500);
        
        // Keep loading until no more posts
        while (attempts < maxAttempts) {
            attempts++;
            
            // Scroll to bottom to trigger lazy loading
            scrollToBottom();
            await sleep(1000);
            
            // Try to click load more button
            const clicked = clickLoadMore();
            if (clicked) {
                addLog('info', `تم النقر على "مشاهدة المزيد" - المحاولة ${attempts}`);
                await sleep(2000); // Wait for posts to load
            }
            
            // Count posts
            currentCount = countPosts();
            
            // If count hasn't changed, we might be done
            if (currentCount === previousCount) {
                // Try one more time to be sure
                scrollToBottom();
                await sleep(1000);
                const finalClick = clickLoadMore();
                if (!finalClick) {
                    // No more load button, we're done
                    break;
                }
                await sleep(2000);
                currentCount = countPosts();
                if (currentCount === previousCount) {
                    break;
                }
            }
            
            addLog('info', `تم تحميل ${currentCount} إعلان حتى الآن...`);
            previousCount = currentCount;
        }
        
        // Scroll back to top
        scrollToTop();
        await sleep(500);
        
        // Final collection
        collectPostIds();
        
        document.getElementById('load-posts-btn').disabled = false;
        document.getElementById('load-posts-btn').textContent = '📋 تحميل الإعلانات';
    }
    
    // Helper sleep function
    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    // Collect post IDs from page
    function collectPostIds() {
        postIds = [];
        postsData = [];
        const postElements = document.querySelectorAll('[data-test-postid]');
        
        postElements.forEach(el => {
            const postId = el.getAttribute('data-test-postid');
            if (postId) {
                postIds.push(parseInt(postId));
                
                // Try to extract post data (image and title)
                const postData = {
                    id: parseInt(postId),
                    title: '',
                    image: ''
                };
                
                // Try to find title
                const titleEl = el.querySelector('[data-testid="post-title"], h3, h2, .post-title');
                if (titleEl) {
                    postData.title = titleEl.textContent.trim();
                }
                
                // Try to find image
                const imageEl = el.querySelector('img[src*="haraj"], img[data-src*="haraj"], img');
                if (imageEl) {
                    postData.image = imageEl.src || imageEl.dataset.src || '';
                }
                
                postsData.push(postData);
            }
        });

        stats.total = postIds.length;
        stats.updated = 0;
        stats.failed = 0;
        stats.skipped = 0;
        stats.liked = 0;
        currentIndex = 0;

        updateStats();

        if (postIds.length > 0) {
            addLog('success', `تم تحميل ${postIds.length} إعلان`);
            document.getElementById('start-btn').disabled = false;
            document.getElementById('like-all-btn').disabled = false;
        } else {
            addLog('error', 'لم يتم العثور على إعلانات');
        }
    }

    // Start updating
    async function startUpdating() {
        // Always try to extract token
        if (!CONFIG.token || !extractToken()) {
            addLog('error', 'فشل في استخراج التوكن. الرجاء الضغط على "تحديث التوكن"');
            return;
        }

        // Validate token before starting
        addLog('info', 'جاري التحقق من صلاحية التوكن...');
        const isValid = await validateToken();
        
        if (!isValid) {
            addLog('error', '❌ التوكن غير صالح. الرجاء تسجيل الدخول مرة أخرى أو الضغط على "تحديث التوكن"');
            return;
        }

        isRunning = true;
        document.getElementById('start-btn').disabled = true;
        document.getElementById('stop-btn').disabled = false;
        document.getElementById('load-posts-btn').disabled = true;
        document.getElementById('like-all-btn').disabled = true;

        addLog('info', 'بدء التحديث...');
        
        await updateBatch();
    }

    // Stop updating
    function stopUpdating() {
        isRunning = false;
        isLiking = false;
        document.getElementById('start-btn').disabled = false;
        document.getElementById('stop-btn').disabled = true;
        document.getElementById('load-posts-btn').disabled = false;
        document.getElementById('like-all-btn').disabled = false;
        addLog('info', 'تم إيقاف التحديث');
    }

    // Update batch of ads
    async function updateBatch() {
        if (!isRunning || currentIndex >= postIds.length) {
            if (currentIndex >= postIds.length) {
                addLog('success', '✅ اكتمل التحديث!');
                playFinishSound();
                stopUpdating();
            }
            return;
        }

        const batch = postIds.slice(currentIndex, currentIndex + CONFIG.adsPerBatch);
        
        for (let postId of batch) {
            if (!isRunning) break;
            await updatePost(postId);
        }

        currentIndex += CONFIG.adsPerBatch;
        updateStats();

        if (isRunning && currentIndex < postIds.length) {
            setTimeout(() => updateBatch(), CONFIG.updateInterval);
        } else if (currentIndex >= postIds.length) {
            addLog('success', '✅ اكتمل التحديث!');
            playFinishSound();
            stopUpdating();
        }
    }
    
    // Play finish sound
    function playFinishSound() {
        try {
            // Create audio context
            const audioContext = new (window.AudioContext || window.webkitAudioContext)();
            
            // Success sound: three ascending notes
            const playNote = (frequency, startTime, duration) => {
                const oscillator = audioContext.createOscillator();
                const gainNode = audioContext.createGain();
                
                oscillator.connect(gainNode);
                gainNode.connect(audioContext.destination);
                
                oscillator.frequency.value = frequency;
                oscillator.type = 'sine';
                
                gainNode.gain.setValueAtTime(0.3, startTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
                
                oscillator.start(startTime);
                oscillator.stop(startTime + duration);
            };
            
            const now = audioContext.currentTime;
            playNote(523.25, now, 0.2);        // C5
            playNote(659.25, now + 0.2, 0.2);  // E5
            playNote(783.99, now + 0.4, 0.4);  // G5
            
            addLog('success', '🔔 تم تشغيل صوت الإنتهاء');
        } catch (e) {
            console.log('Could not play sound:', e);
        }
    }

    // Update single post
    async function updatePost(postId) {
        try {
            const response = await fetch(CONFIG.graphqlEndpoint + '?queryName=updatePost&clientId=ymZn1c5V-kFw1-HIfT-5zEd-mEHP5dmkhQ6Rv3&version=N0.0.1', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    query: `mutation updatePost($token: String!, $id: Int!) {
                        updatePost(token: $token, id: $id) {
                            status
                            notValidReason
                        }
                    }`,
                    variables: {
                        token: CONFIG.token,
                        id: postId
                    }
                })
            });

            const data = await response.json();
            console.log(`Post ${postId} response:`, data);
            
            // Find post data
            const postData = postsData.find(p => p.id === postId) || { id: postId, title: `إعلان #${postId}`, image: '' };
            
            // Check if update was successful
            if (data.data?.updatePost?.status === true || data.data?.updatePost?.status === 'success') {
                stats.updated++;
                addLog('success', `✓ تم تحديث الإعلان`, postData);
            } else if (data.errors && data.errors.some(e => e.message && e.message.includes('لم يتم تسجيل الدخول'))) {
                // Token is invalid - stop everything
                stats.failed++;
                addLog('error', `✗ التوكن غير صالح - لم يتم تسجيل الدخول`, postData);
                updateTokenStatus(false);
                stopUpdating();
                addLog('error', '❌ تم إيقاف التحديث: التوكن غير صالح. الرجاء الضغط على "تحديث التوكن"');
            } else {
                // Update failed - show the reason
                stats.failed++;
                const reason = data.data?.updatePost?.notValidReason || data.errors?.[0]?.message || 'فشل التحديث';
                addLog('error', `✗ ${reason}`, postData);
                console.error(`Failed to update post ${postId}:`, reason);
            }
        } catch (error) {
            stats.failed++;
            const postData = postsData.find(p => p.id === postId) || { id: postId, title: `إعلان #${postId}`, image: '' };
            addLog('error', `✗ خطأ في الإعلان: ${error.message}`, postData);
            console.error(`Error updating post ${postId}:`, error);
        }
    }

    // Update statistics
    function updateStats() {
        document.getElementById('stat-total').textContent = stats.total;
        document.getElementById('stat-updated').textContent = stats.updated;
        document.getElementById('stat-failed').textContent = stats.failed;
        document.getElementById('stat-remaining').textContent = Math.max(0, stats.total - currentIndex);

        const progress = stats.total > 0 ? (currentIndex / stats.total) * 100 : 0;
        document.getElementById('progress-fill').style.width = progress + '%';
    }

    // Add log entry
    function addLog(type, message, postData = null) {
        const logContainer = document.getElementById('log-container');
        const entry = document.createElement('div');
        entry.className = `log-entry ${type}`;
        
        const icon = type === 'success' ? '✓' : type === 'error' ? '✗' : 'ℹ';
        
        let html = `<div style="display: flex; align-items: center; gap: 8px;">
            <span class="log-icon">${icon}</span>
            <span>${message}</span>
        </div>`;
        
        // Add post info if available
        if (postData && (postData.title || postData.image)) {
            html += `<div class="log-ad-info">`;
            
            if (postData.image) {
                html += `<img src="${postData.image}" class="log-ad-image" alt="صورة الإعلان" onerror="this.style.display='none'">`;
            }
            
            html += `<div class="log-ad-title">${postData.title || `إعلان #${postData.id}`}</div>`;
            html += `</div>`;
        }
        
        entry.innerHTML = html;
        
        logContainer.insertBefore(entry, logContainer.firstChild);
        
        // Keep only last 50 entries
        while (logContainer.children.length > 50) {
            logContainer.removeChild(logContainer.lastChild);
        }
    }

    // Like all ads
    async function likeAllAds() {
        if (!CONFIG.token) {
            if (!extractToken()) {
                addLog('error', 'فشل في استخراج التوكن. الرجاء إدخال التوكن يدوياً');
                return;
            }
        }

        // Validate token
        const isValid = await validateToken();
        if (!isValid) {
            addLog('error', '❌ التوكن غير صالح. الرجاء تسجيل الدخول مرة أخرى');
            return;
        }

        isLiking = true;
        document.getElementById('like-all-btn').disabled = true;
        document.getElementById('start-btn').disabled = true;
        document.getElementById('stop-btn').disabled = false;

        addLog('info', 'بدء تفضيل جميع الإعلانات...');

        for (let i = 0; i < postIds.length; i++) {
            if (!isLiking) break;

            const postId = postIds[i];
            await likePost(postId);
            
            // Update progress
            const progress = ((i + 1) / postIds.length) * 100;
            document.getElementById('progress-fill').style.width = progress + '%';
            
            // Wait between requests
            await sleep(CONFIG.updateInterval);
        }

        addLog('success', `✅ تم تفضيل ${stats.liked} إعلان`);
        stopUpdating();
    }

    // Like single post
    async function likePost(postId) {
        try {
            const response = await fetch(CONFIG.graphqlEndpoint + '?queryName=submitLike&clientId=ymZn1c5V-kFw1-HIfT-5zEd-mEHP5dmkhQ6Rv3&version=N0.0.1', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    query: `mutation {
                        submitLike(token: "${CONFIG.token}", id: ${postId})
                    }`
                })
            });

            const data = await response.json();
            console.log(`Like post ${postId} response:`, data);
            
            const postData = postsData.find(p => p.id === postId) || { id: postId, title: `إعلان #${postId}`, image: '' };
            
            if (data.data?.submitLike) {
                stats.liked++;
                addLog('success', `❤️ تم تفضيل الإعلان`, postData);
            } else {
                addLog('error', `فشل تفضيل الإعلان`, postData);
            }
        } catch (error) {
            const postData = postsData.find(p => p.id === postId) || { id: postId, title: `إعلان #${postId}`, image: '' };
            addLog('error', `خطأ في تفضيل الإعلان: ${error.message}`, postData);
            console.error(`Error liking post ${postId}:`, error);
        }
    }

    // Create Quick Reply UI
    function createQuickReplyUI() {
        // Create modal only
        const modal = document.createElement('div');
        modal.className = 'quick-reply-modal';
        modal.id = 'quick-reply-modal';
        modal.innerHTML = `
            <div class="quick-reply-modal-content">
                <h3>إدارة الردود السريعة</h3>
                <textarea id="quick-reply-input" placeholder="اكتب رسالتك هنا..."></textarea>
                <div class="quick-reply-modal-buttons">
                    <button class="confirm" id="add-quick-reply">إضافة</button>
                    <button class="cancel" id="cancel-quick-reply">إلغاء</button>
                </div>
                <div class="quick-reply-list" id="quick-reply-list"></div>
            </div>
        `;
        document.body.appendChild(modal);

        // Event listeners
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.remove('active');
            }
        });

        document.getElementById('add-quick-reply').addEventListener('click', addQuickReply);
        document.getElementById('cancel-quick-reply').addEventListener('click', () => {
            modal.classList.remove('active');
        });

        // Load saved quick replies
        loadQuickReplies();
    }

    // Check if we're on a chat page
    function checkChatPage() {
        try {
            // Only run on chat pages
            if (!window.location.href.includes('/chat') && !window.location.href.includes('/messages')) {
                return;
            }

            // Check if already injected
            if (document.querySelector('.quick-reply-panel')) {
                return;
            }

            // Look for the chat textarea
            const chatTextarea = document.querySelector('textarea[id*="chat"]') || 
                                document.querySelector('textarea[placeholder*="رسالة"]') ||
                                document.querySelector('#chat-textbox');
            
            if (!chatTextarea) {
                return;
            }

            // Create floating panel
            const panel = document.createElement('div');
            panel.className = 'quick-reply-panel';
            
            const header = document.createElement('div');
            header.className = 'quick-reply-panel-header';
            header.innerHTML = '<span>💬 ردود سريعة</span>';
            
            const closeBtn = document.createElement('button');
            closeBtn.className = 'quick-reply-panel-close';
            closeBtn.textContent = '×';
            closeBtn.addEventListener('click', () => panel.remove());
            header.appendChild(closeBtn);
            
            const body = document.createElement('div');
            body.className = 'quick-reply-panel-body';
            body.id = 'quick-reply-panel-body';
            
            if (CONFIG.quickReplies.length === 0) {
                body.innerHTML = '<div class="quick-reply-empty">لا توجد ردود سريعة<br><small>اضغط على زر "الردود السريعة" في القائمة لإضافة ردود</small></div>';
            } else {
                CONFIG.quickReplies.forEach((reply, index) => {
                    const item = document.createElement('div');
                    item.className = 'quick-reply-item-panel';
                    
                    const sendBtn = document.createElement('button');
                    sendBtn.className = 'quick-reply-send-btn';
                    sendBtn.textContent = '📤';
                    sendBtn.addEventListener('click', () => {
                        window.harajUpdater.sendQuickReply(reply);
                    });
                    
                    const textDiv = document.createElement('div');
                    textDiv.className = 'quick-reply-text-panel';
                    textDiv.textContent = reply;
                    
                    const numberSpan = document.createElement('span');
                    numberSpan.className = 'quick-reply-number';
                    numberSpan.textContent = index + 1;
                    
                    item.appendChild(sendBtn);
                    item.appendChild(textDiv);
                    item.appendChild(numberSpan);
                    body.appendChild(item);
                });
            }
            
            panel.appendChild(header);
            panel.appendChild(body);
            document.body.appendChild(panel);
            
            console.log('✅ Quick reply panel injected successfully');
        } catch (error) {
            console.error('Error in checkChatPage:', error);
        }
    }

    // Render quick reply buttons in panel
    function renderQuickReplyPanel() {
        const body = document.getElementById('quick-reply-panel-body');
        if (!body) return;

        // Clear existing content
        body.innerHTML = '';

        if (CONFIG.quickReplies.length === 0) {
            body.innerHTML = '<div class="quick-reply-empty">لا توجد ردود سريعة<br><small>اضغط على زر "الردود السريعة" في القائمة لإضافة ردود</small></div>';
            return;
        }

        CONFIG.quickReplies.forEach((reply, index) => {
            const item = document.createElement('div');
            item.className = 'quick-reply-item-panel';
            
            const sendBtn = document.createElement('button');
            sendBtn.className = 'quick-reply-send-btn';
            sendBtn.textContent = '📤';
            sendBtn.addEventListener('click', () => {
                window.harajUpdater.sendQuickReply(reply);
            });
            
            const textDiv = document.createElement('div');
            textDiv.className = 'quick-reply-text-panel';
            textDiv.textContent = reply;
            
            const numberSpan = document.createElement('span');
            numberSpan.className = 'quick-reply-number';
            numberSpan.textContent = index + 1;
            
            item.appendChild(sendBtn);
            item.appendChild(textDiv);
            item.appendChild(numberSpan);
            body.appendChild(item);
        });
    }

    // Open quick reply modal
    function openQuickReplyModal() {
        const modal = document.getElementById('quick-reply-modal');
        modal.classList.add('active');
        renderQuickReplyList();
    }

    // Add quick reply
    function addQuickReply() {
        const input = document.getElementById('quick-reply-input');
        const text = input.value.trim();
        
        if (!text) {
            alert('الرجاء إدخال نص الرسالة');
            return;
        }

        CONFIG.quickReplies.push(text);
        GM_setValue('quickReplies', CONFIG.quickReplies);
        
        input.value = '';
        renderQuickReplyList();
        renderQuickReplyPanel();
        
        addLog('success', 'تم إضافة رد سريع جديد');
    }

    // Remove quick reply
    function removeQuickReply(index) {
        CONFIG.quickReplies.splice(index, 1);
        GM_setValue('quickReplies', CONFIG.quickReplies);
        renderQuickReplyList();
        renderQuickReplyPanel();
        addLog('info', 'تم حذف الرد السريع');
    }

    // Render quick reply list in modal
    function renderQuickReplyList() {
        const list = document.getElementById('quick-reply-list');
        if (!list) return;

        if (CONFIG.quickReplies.length === 0) {
            list.innerHTML = '<p style="text-align: center; color: #999; padding: 20px;">لا توجد ردود سريعة</p>';
            return;
        }

        list.innerHTML = CONFIG.quickReplies.map((reply, index) => `
            <div class="quick-reply-item">
                <div class="quick-reply-item-text">${reply}</div>
                <button class="quick-reply-item-remove" onclick="window.harajUpdater.removeQuickReply(${index})">حذف</button>
            </div>
        `).join('');
    }

    // Insert quick reply into chat
    function insertQuickReply(index) {
        const reply = CONFIG.quickReplies[index];
        if (!reply) return;

        // Try to find chat textarea
        const textarea = document.querySelector('textarea[id*="chat"], textarea[placeholder*="رسالة"], #chat-textbox');
        
        if (textarea) {
            textarea.value = reply;
            textarea.focus();
            
            // Trigger input event to update any React/Vue state
            const event = new Event('input', { bubbles: true });
            textarea.dispatchEvent(event);
            
            addLog('success', 'تم إدراج الرد السريع');
        } else {
            // Copy to clipboard as fallback
            navigator.clipboard.writeText(reply).then(() => {
                addLog('success', 'تم نسخ الرد السريع إلى الحافظة');
            });
        }
    }

    // Load quick replies
    function loadQuickReplies() {
        CONFIG.quickReplies = GM_getValue('quickReplies', []);
    }

    // Initialize
    function init() {
        // Wait for page to load
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                createMenu();
                setupChatObserver();
            });
        } else {
            createMenu();
            setupChatObserver();
        }

        addLog('info', 'تم تحميل محدث حراج بنجاح');
        
        // Try to extract token on load
        setTimeout(() => {
            if (extractToken()) {
                validateToken();
            }
        }, 1000);
    }

    // Setup observer for chat pages
    function setupChatObserver() {
        // Check immediately if on chat page
        if (window.location.href.includes('/chat') || window.location.href.includes('/messages')) {
            setTimeout(checkChatPage, 1000);
        }
        
        // Watch for URL changes using a simple interval (safer than MutationObserver)
        let lastUrl = location.href;
        setInterval(() => {
            const url = location.href;
            if (url !== lastUrl) {
                lastUrl = url;
                if (url.includes('/chat') || url.includes('/messages')) {
                    setTimeout(checkChatPage, 500);
                }
            }
        }, 2000); // Check every 2 seconds (not too aggressive)
    }

    // Start the script
    init();
})();
