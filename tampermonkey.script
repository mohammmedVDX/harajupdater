            font-style: italic;
        }
        
        .ai-preview-box {
            background: rgba(0,0,0,0.4);
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            padding: 10px;
            margin: 10px 0;
            max-height: 150px;
            overflow-y: auto;
            font-size: 12px;
            white-space: pre-wrap;
